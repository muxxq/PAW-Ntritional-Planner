        decimal kcal_consumed
        decimal proteins_consumed
        decimal carbs_consumed
        decimal fats_consumed
        datetime logged_at
    }
    MEAL_PLANNERS {
        int id PK
        int user_id FK
        date plan_date
        string meal_type
        string notes
    }
    PLANNER_ITEMS {
        int id PK
        int planner_id FK
        int recipe_id FK
        int ingredient_id FK
        decimal quantity
    }
    SHOPPING_LISTS {
        int id PK
        int user_id FK
        string name
        datetime created_at
    }
