        int carbs_target_g
        int fats_target_g
        datetime created_at
    }
    INGREDIENTS {
        int id PK
        string name UK
        decimal calories_per_100g
        decimal proteins
        decimal carbs
        decimal fats
        decimal sugars
        string unit
    }
