@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recipes</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Project styles (load after Bootstrap so it can override) -->
    <link rel="stylesheet" href="assets/css/style.css">
</head>

<body>
    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-light fixed-top shadow-sm">
  <div class="container">
    <a class="navbar-brand text-success" href="/Home/Index">NutriPlan</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link" href="/Home/Index">Home</a></li>
        <li class="nav-item"><a class="nav-link" href="/Home/Dashboard">Dashboard</a></li>
        <li class="nav-item"><a class="nav-link" href="/Home/Meals">Meals</a></li>
        <li class="nav-item"><a class="nav-link" href="/Home/Planner">Planner</a></li>
        <li class="nav-item"><a class="nav-link active" href="/Home/Recipes">Recipes</a></li>
        <li class="nav-item"><a class="nav-link" href="/Home/ShoppingList">Shopping list</a></li>
        <li class="nav-item"><a class="nav-link" href="/Home/Profile">Profile</a></li>
      </ul>
      <div class="d-flex">
        <a href="/Home/Login" class="btn btn-outline-primary btn-sm me-1">Log in</a>
        <a href="/Home/Register" class="btn btn-outline-secondary btn-sm">Sign up</a>
      </div>
    </div>
  </div>
</nav>

    <main class="container" style="padding-top:80px; padding-bottom:80px;">
        <div class="row justify-content-center">
            <div class="col-12 col-md-10 col-lg-8">
                <h2 class="mb-3">Recipes</h2>

                <!-- Search (UI only) -->
                <div class="input-group mb-4">
                    <input type="search" class="form-control" placeholder="Search recipes..." aria-label="Search recipes">
                    <button class="btn btn-secondary" type="button">Search</button>
                </div>

                <!-- Mock recipe list -->
                <ul class="list-group">
                    <li class="list-group-item d-flex justify-content-between align-items-start">
                        <div>
                            <div class="fw-bold">Grilled chicken salad</div>
                            <div class="small text-muted">Fresh greens, grilled chicken, vinaigrette</div>
                        </div>
                        <span class="badge bg-secondary rounded-pill">420 kcal</span>
                    </li>

                    <li class="list-group-item d-flex justify-content-between align-items-start">
                        <div>
                            <div class="fw-bold">Veggie Buddha Bowl</div>
                            <div class="small text-muted">Roasted veg, quinoa, tahini</div>
                        </div>
                        <span class="badge bg-secondary rounded-pill">550 kcal</span>
                    </li>

                    <li class="list-group-item d-flex justify-content-between align-items-start">
                        <div>
                            <div class="fw-bold">Spaghetti Bolognese</div>
                            <div class="small text-muted">Classic beef ragu over pasta</div>
                        </div>
                        <span class="badge bg-secondary rounded-pill">680 kcal</span>
                    </li>

                    <li class="list-group-item d-flex justify-content-between align-items-start">
                        <div>
                            <div class="fw-bold">Blueberry pancakes</div>
                            <div class="small text-muted">Fluffy pancakes with fresh berries</div>
                        </div>
                        <span class="badge bg-secondary rounded-pill">520 kcal</span>
                    </li>

                    <li class="list-group-item d-flex justify-content-between align-items-start">
                        <div>
                            <div class="fw-bold">Quinoa & black beans</div>
                            <div class="small text-muted">Protein-packed bowl with lime</div>
                        </div>
                        <span class="badge bg-secondary rounded-pill">480 kcal</span>
                    </li>
                </ul>
            </div>
        </div>
    </main>

    <footer class="bg-light py-3 fixed-bottom">
  <div class="container text-center">
    <span class="text-muted small">&copy; 2026 NutriPlan. All rights reserved.</span>
  </div>
</footer>

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>

