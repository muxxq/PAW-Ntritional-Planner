@model paw_np.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Log in";
}

<div class="card shadow-lg" style="max-width: 420px; margin: auto;">
    <form asp-action="Login" method="post" class="p-4">
        @Html.AntiForgeryToken()
        <h3 class="mb-3 text-center">Log in</h3>
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
        <div class="mb-3">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" class="form-control" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        <div class="mb-3 form-check">
            <input asp-for="RememberMe" class="form-check-input" />
            <label asp-for="RememberMe" class="form-check-label"></label>
        </div>
        <button type="submit" class="btn btn-primary w-100">Log in</button>
        <div class="text-center mt-3 small">
            <a asp-action="Register">Don't have an account? Sign up</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

