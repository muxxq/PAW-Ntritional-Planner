@model paw_np.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4">Today's Overview — @Model.Today.ToString("dd MMM yyyy")</h2>

<div class="row g-4">
    <!-- Calories Card -->
    <div class="col-12 col-md-6">
        <div class="card h-100">
            <div class="card-header text-uppercase fw-bold text-primary">CALORIES</div>
            <div class="card-body d-flex flex-column justify-content-center">
                <div class="mb-3">
                    <strong class="fs-4">@Model.CaloriesConsumed / @Model.CaloricTarget kcal</strong>
                    <div class="small text-muted">Calories consumed vs daily target</div>
                </div>
                <div class="progress" style="height:20px;">
                    @{
                        var pct = Math.Min(Model.CaloriesPercentage, 100);
                        var barColor = pct > 90 ? "bg-danger" : pct > 70 ? "bg-warning" : "bg-primary";
                    }
                    <div class="progress-bar @barColor" role="progressbar"
                        style="width:@(pct)%;" aria-valuenow="@Model.CaloriesConsumed"
                        aria-valuemin="0" aria-valuemax="@Model.CaloricTarget">
                        @(Model.CaloriesPercentage)%
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Macros Card -->
    <div class="col-12 col-md-6">
        <div class="card h-100">
            <div class="card-header text-uppercase fw-bold text-success">MACROS</div>
            <div class="card-body">
                <!-- Protein -->
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span>Protein</span>
                        <strong>@Model.TotalProteins g</strong>
                    </div>
                    <div class="progress" style="height:12px;">
                        <div class="progress-bar bg-info" role="progressbar"
                            style="width: @(Math.Min((double)Model.TotalProteins, 200) / 2)%;"></div>
                    </div>
                </div>
                <!-- Carbs -->
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span>Carbs</span>
                        <strong>@Model.TotalCarbs g</strong>
                    </div>
                    <div class="progress" style="height:12px;">
                        <div class="progress-bar bg-warning" role="progressbar"
                            style="width: @(Math.Min((double)Model.TotalCarbs, 300) / 3)%;"></div>
                    </div>
                </div>
                <!-- Fats -->
                <div class="mb-1">
                    <div class="d-flex justify-content-between mb-1">
                        <span>Fats</span>
                        <strong>@Model.TotalFats g</strong>
                    </div>
                    <div class="progress" style="height:12px;">
                        <div class="progress-bar bg-danger" role="progressbar"
                            style="width: @(Math.Min((double)Model.TotalFats, 100))%;"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Stats -->
<div class="row g-4 mt-2">
    <div class="col-6 col-md">
        <div class="card text-center">
            <div class="card-body">
                <div class="fs-2 fw-bold text-primary">@Model.TotalIngredients</div>
                <div class="small text-muted">Ingredients</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md">
        <div class="card text-center">
            <div class="card-body">
                <div class="fs-2 fw-bold text-success">@Model.TotalRecipes</div>
                <div class="small text-muted">Recipes</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md">
        <div class="card text-center">
            <div class="card-body">
                <div class="fs-2 fw-bold text-info">@Model.TotalJournals</div>
                <div class="small text-muted">Journals</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md">
        <div class="card text-center">
            <div class="card-body">
                <div class="fs-2 fw-bold text-warning">@Model.TotalMealPlans</div>
                <div class="small text-muted">Meal Plans</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md">
        <div class="card text-center">
            <div class="card-body">
                <div class="fs-2 fw-bold text-secondary">@Model.TotalShoppingLists</div>
                <div class="small text-muted">Shopping Lists</div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Journals + Upcoming Plans -->
<div class="row g-4 mt-2">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">Recent Journals</div>
            <div class="card-body p-0">
                @if (Model.RecentJournals.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var journal in Model.RecentJournals)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <a asp-controller="FoodJournal" asp-action="Details" asp-route-id="@journal.Id">
                                        @journal.JournalDate.ToString("dd MMM yyyy")
                                    </a>
                                    <span class="text-muted small ms-2">(@journal.EntriesCount entries)</span>
                                </div>
                                <span class="badge bg-primary rounded-pill">@journal.TotalKcalConsumed kcal</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="p-3 text-muted">No journals yet.</div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">Upcoming Meal Plans</div>
            <div class="card-body p-0">
                @if (Model.UpcomingPlans.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var plan in Model.UpcomingPlans)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <a asp-controller="MealPlanner" asp-action="Details" asp-route-id="@plan.Id">
                                        @plan.PlanDate.ToString("dd MMM") — @plan.MealType
                                    </a>
                                    <span class="text-muted small ms-2">(@plan.ItemsCount items)</span>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="p-3 text-muted">No upcoming plans.</div>
                }
            </div>
        </div>
    </div>
</div>
