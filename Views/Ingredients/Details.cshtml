@model NutriPlan.Models.Ingredient

@{
    ViewData["Title"] = "Ingredient Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Ingredient Details</h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-outline-secondary">Edit</a>
        <a asp-action="Index" class="btn btn-outline-primary">Back to List</a>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-light">
                <h4 class="mb-0 fw-bold">@Model.Name</h4>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Default Unit</dt>
                    <dd class="col-sm-8 fw-bold">@Model.Unit</dd>

                    <dt class="col-sm-4 text-muted mt-3">Kcal per 100@(Model.Unit)</dt>
                    <dd class="col-sm-8 mt-3"><span class="badge bg-primary fs-6">@Math.Round(Model.CaloriesPer100g, 1) kcal</span></dd>
                </dl>
                
                <hr class="my-4" />
                <h5 class="text-muted mb-3">Macronutrients (per 100@(Model.Unit))</h5>
                
                <div class="row text-center">
                    <div class="col-3">
                        <div class="text-success fw-bold fs-5">@Math.Round(Model.Proteins, 1)g</div>
                        <div class="small text-muted">Proteins</div>
                    </div>
                    <div class="col-3">
                        <div class="text-warning text-dark fw-bold fs-5">@Math.Round(Model.Carbs, 1)g</div>
                        <div class="small text-muted">Carbs</div>
                    </div>
                    <div class="col-3">
                        <div class="text-danger fw-bold fs-5">@Math.Round(Model.Fats, 1)g</div>
                        <div class="small text-muted">Fats</div>
                    </div>
                    <div class="col-3">
                        <div class="text-info text-dark fw-bold fs-5">@Math.Round(Model.Sugars, 1)g</div>
                        <div class="small text-muted">Sugars</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
