@model NutriPlan.Models.Ingredient

@{
    ViewData["Title"] = "Delete Ingredient";
}

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0">Delete Ingredient</h4>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <strong>Are you sure you want to delete this?</strong> This action cannot be undone.
                </div>

                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Ingredient</dt>
                    <dd class="col-sm-8 fw-bold">@Model.Name</dd>

                    <dt class="col-sm-4 text-muted">Kcal/100@(Model.Unit)</dt>
                    <dd class="col-sm-8">@Math.Round(Model.CaloriesPer100g, 1)</dd>
                </dl>
                
                <hr class="my-4" />

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">Confirm Delete</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
