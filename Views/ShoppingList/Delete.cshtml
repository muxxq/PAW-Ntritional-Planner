@model paw_np.Models.ViewModels.ShoppingListDeleteViewModel

@{
    ViewData["Title"] = "Delete Shopping List";
}

<h1 class="h3 mb-3">Delete Shopping List</h1>

<div class="alert alert-warning">
    Are you sure you want to delete this list?
</div>

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">User ID</dt>
    <dd class="col-sm-9">@Model.UserId</dd>

    <dt class="col-sm-3">Created</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>

    <dt class="col-sm-3">Items</dt>
    <dd class="col-sm-9">@Model.ItemCount</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-link">Back to List</a>
</form>
