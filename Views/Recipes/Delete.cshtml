@model NutriPlan.Models.Recipe

@{
    ViewData["Title"] = "Delete Recipe";
}

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0">Delete Recipe</h4>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <strong>Are you sure you want to delete this recipe?</strong> This action cannot be undone.
                </div>

                <h5 class="fw-bold">@Model.Name</h5>
                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <p class="text-muted">@Model.Description</p>
                }

                <div class="row text-center mt-4">
                    <div class="col-4">
                        <div class="fw-bold">@Model.Servings</div>
                        <div class="small text-muted">Servings</div>
                    </div>
                    <div class="col-4 border-start border-end">
                        <div class="fw-bold">@(Model.PrepTimeMin + Model.CookTimeMin)m</div>
                        <div class="small text-muted">Total Time</div>
                    </div>
                    <div class="col-4">
                        <div class="text-primary fw-bold">@Math.Round(Model.TotalKcal, 1)</div>
                        <div class="small text-muted">Total Kcal</div>
                    </div>
                </div>

                <hr class="my-4" />

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">Confirm Delete</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
