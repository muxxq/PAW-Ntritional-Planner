@model NutriPlan.Models.Recipe

@{
    ViewData["Title"] = Model.Name;
    var availableIngredients = ViewBag.AvailableIngredients as List<paw_np.Models.ViewModels.IngredientOptionViewModel> ?? new();
}

<h2 class="mb-4">@Model.Name</h2>

@if (TempData["Error"] is not null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@(Model.Description ?? "-")</dd>

            <dt class="col-sm-3">Servings</dt>
            <dd class="col-sm-9">@Model.Servings</dd>

            <dt class="col-sm-3">Prep Time</dt>
            <dd class="col-sm-9">@Model.PrepTimeMin min</dd>

            <dt class="col-sm-3">Cook Time</dt>
            <dd class="col-sm-9">@Model.CookTimeMin min</dd>

            <dt class="col-sm-3">Total Kcal</dt>
            <dd class="col-sm-9">@Model.TotalKcal</dd>

            <dt class="col-sm-3">Created</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToString("dd MMM yyyy")</dd>
        </dl>
    </div>
</div>

<h4>Ingredients</h4>

@if (!Model.RecipeIngredients.Any())
{
    <div class="alert alert-info">No ingredients added yet.</div>
}
else
{
    <div class="card mb-4">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Ingredient</th>
                        <th class="text-center">Quantity</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var ri in Model.RecipeIngredients)
                {
                    <tr>
                        <td><strong>@ri.Ingredient.Name</strong></td>
                        <td class="text-center">@ri.Quantity @ri.Unit</td>
                        <td class="text-end pe-3">
                            <form asp-action="DeleteIngredient" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@ri.Id" />
                                <input type="hidden" name="recipeId" value="@Model.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('Remove this ingredient?')">Remove</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="card mb-4">
    <div class="card-header">Add Ingredient</div>
    <div class="card-body">
        <form asp-action="AddIngredient" method="post" class="row g-3 align-items-end">
            @Html.AntiForgeryToken()
            <input type="hidden" name="recipeId" value="@Model.Id" />

            <div class="col-md-5">
                <label class="form-label">Ingredient</label>
                <select name="ingredientId" class="form-select" required>
                    <option value="">-- Select ingredient --</option>
                    @foreach (var ingredient in availableIngredients)
                    {
                        <option value="@ingredient.Id">@ingredient.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Quantity</label>
                <input name="quantity" class="form-control" type="number" step="0.01" min="0.01" value="1" required />
            </div>
            <div class="col-md-2">
                <label class="form-label">Unit</label>
                <input name="unit" class="form-control" value="g" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Add</button>
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>
