@model NutriPlan.Models.Recipe

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

@if (TempData["Error"] is not null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div>
    <h4>Recipe</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Servings)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Servings)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.PrepTimeMin)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.PrepTimeMin)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.CookTimeMin)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CookTimeMin)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.TotalKcal)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TotalKcal)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.CreatedAt)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CreatedAt)
        </dd>
    </dl>
</div>

<hr />

<h4>Ingredients</h4>

@if (!Model.RecipeIngredients.Any())
{
    <div class="alert alert-info">No ingredients added yet.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Ingredient</th>
                <th>Quantity</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var ri in Model.RecipeIngredients)
        {
            <tr>
                <td>@ri.Ingredient.Name</td>
                <td>@ri.Quantity @ri.Unit</td>
                <td class="text-end">
                    <form asp-action="DeleteIngredient" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@ri.Id" />
                        <input type="hidden" name="recipeId" value="@Model.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<div class="card mb-4">
    <div class="card-header">Add ingredient</div>
    <div class="card-body">
        <form asp-action="AddIngredient" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <input type="hidden" name="recipeId" value="@Model.Id" />

            <div class="col-md-6">
                <label class="form-label">Ingredient ID</label>
                <input name="ingredientId" class="form-control" type="number" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Quantity</label>
                <input name="quantity" class="form-control" type="number" step="0.01" value="1" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Unit</label>
                <input name="unit" class="form-control" value="g" />
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary">Add</button>
            </div>
        </form>
        <div class="form-text">
            Temporary: use Ingredient ID. Next step: dropdown with your ingredients.
        </div>
    </div>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
