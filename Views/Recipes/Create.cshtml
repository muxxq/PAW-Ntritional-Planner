@model paw_np.Models.ViewModels.RecipeCreateViewModel

@{
    ViewData["Title"] = "Create Recipe";
}

<h2 class="mb-4">Create Recipe</h2>

<div class="row">
    <div class="col-lg-6">
        <div class="card mb-4">
            <div class="card-header">Recipe Details</div>
            <div class="card-body">
                <form asp-action="Create" method="post" id="recipeForm">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-group mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <input asp-for="Description" class="form-control" />
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="Instructions" class="form-label"></label>
                        <textarea asp-for="Instructions" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Instructions" class="text-danger"></span>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label asp-for="Servings" class="form-label"></label>
                            <input asp-for="Servings" class="form-control" type="number" min="1" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="PrepTimeMin" class="form-label"></label>
                            <input asp-for="PrepTimeMin" class="form-control" type="number" min="0" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="CookTimeMin" class="form-label"></label>
                            <input asp-for="CookTimeMin" class="form-control" type="number" min="0" />
                        </div>
                    </div>

                    <!-- Hidden container for ingredient rows (posted to server) -->
                    <div id="ingredientHiddenInputs"></div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Create Recipe</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <!-- Add existing ingredient -->
        <div class="card mb-3">
            <div class="card-header">Add Existing Ingredient</div>
            <div class="card-body">
                <div class="row g-2 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label">Ingredient</label>
                        <select id="existingIngredientSelect" class="form-select">
                            <option value="">-- Select --</option>
                            @foreach (var ing in Model.AvailableIngredients)
                            {
                                <option value="@ing.Id">@ing.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Quantity</label>
                        <input id="existingQty" type="number" class="form-control" step="0.01" min="0.01" value="100" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Unit</label>
                        <input id="existingUnit" type="text" class="form-control" value="g" />
                    </div>
                    <div class="col-md-2">
                        <button type="button" class="btn btn-success w-100" onclick="addExistingIngredient()">Add</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Create new ingredient inline -->
        <div class="card mb-3">
            <div class="card-header">Create & Add New Ingredient</div>
            <div class="card-body">
                <p class="text-muted small mb-2">Don't have the ingredient yet? Create it here and it will be added to both your ingredients list and this recipe.</p>
                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label">Name</label>
                        <input id="newIngName" type="text" class="form-control" placeholder="e.g. Lapte" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Calories/100g</label>
                        <input id="newIngCal" type="number" class="form-control" step="0.01" min="0" value="0" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Proteins</label>
                        <input id="newIngProt" type="number" class="form-control" step="0.01" min="0" value="0" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Carbs</label>
                        <input id="newIngCarbs" type="number" class="form-control" step="0.01" min="0" value="0" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Fats</label>
                        <input id="newIngFats" type="number" class="form-control" step="0.01" min="0" value="0" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Qty in recipe</label>
                        <input id="newIngQty" type="number" class="form-control" step="0.01" min="0.01" value="100" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Unit</label>
                        <input id="newIngUnit" type="text" class="form-control" value="g" />
                    </div>
                    <div class="col-md-9 d-flex align-items-end">
                        <button type="button" class="btn btn-warning w-100" onclick="addNewIngredient()">Create & Add</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Ingredient list preview -->
        <div class="card">
            <div class="card-header d-flex justify-content-between">
                <span>Ingredients in this Recipe</span>
                <span class="badge bg-primary" id="ingredientCount">0</span>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0" id="ingredientTable">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th class="text-center">Qty</th>
                            <th class="text-center">Unit</th>
                            <th class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="ingredientRows">
                        <tr id="noIngredientsRow">
                            <td colspan="4" class="text-center text-muted py-3">No ingredients added yet.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        let ingredientIndex = 0;
        const ingredients = [];

        function addExistingIngredient() {
            const select = document.getElementById('existingIngredientSelect');
            const id = parseInt(select.value);
            if (!id) { alert('Selecteaza un ingredient.'); return; }

            const name = select.options[select.selectedIndex].text;
            const qty = parseFloat(document.getElementById('existingQty').value) || 100;
            const unit = document.getElementById('existingUnit').value || 'g';

            // Check duplicate
            if (ingredients.some(i => i.ingredientId === id)) {
                alert('Acest ingredient a fost deja adaugat.');
                return;
            }

            addIngredientRow({
                ingredientId: id,
                name: name,
                qty: qty,
                unit: unit,
                isNew: false
            });

            select.value = '';
            document.getElementById('existingQty').value = '100';
            document.getElementById('existingUnit').value = 'g';
        }

        function addNewIngredient() {
            const name = document.getElementById('newIngName').value.trim();
            if (!name) { alert('Introdu un nume pentru ingredient.'); return; }

            const cal = parseFloat(document.getElementById('newIngCal').value) || 0;
            const prot = parseFloat(document.getElementById('newIngProt').value) || 0;
            const carbs = parseFloat(document.getElementById('newIngCarbs').value) || 0;
            const fats = parseFloat(document.getElementById('newIngFats').value) || 0;
            const qty = parseFloat(document.getElementById('newIngQty').value) || 100;
            const unit = document.getElementById('newIngUnit').value || 'g';

            addIngredientRow({
                ingredientId: 0,
                name: name,
                qty: qty,
                unit: unit,
                isNew: true,
                newCal: cal,
                newProt: prot,
                newCarbs: carbs,
                newFats: fats
            });

            // Reset fields
            document.getElementById('newIngName').value = '';
            document.getElementById('newIngCal').value = '0';
            document.getElementById('newIngProt').value = '0';
            document.getElementById('newIngCarbs').value = '0';
            document.getElementById('newIngFats').value = '0';
            document.getElementById('newIngQty').value = '100';
            document.getElementById('newIngUnit').value = 'g';
        }

        function addIngredientRow(data) {
            const idx = ingredientIndex++;
            ingredients.push({ ...data, index: idx });

            // Hide the "no ingredients" row
            const noRow = document.getElementById('noIngredientsRow');
            if (noRow) noRow.style.display = 'none';

            // Add table row
            const tbody = document.getElementById('ingredientRows');
            const tr = document.createElement('tr');
            tr.id = 'ingredientRow_' + idx;
            tr.innerHTML = `
                <td>${data.isNew ? '<span class="badge bg-warning text-dark me-1">NEW</span>' : ''}${data.name}</td>
                <td class="text-center">${data.qty}</td>
                <td class="text-center">${data.unit}</td>
                <td class="text-end pe-3">
                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeIngredient(${idx})">Remove</button>
                </td>
            `;
            tbody.appendChild(tr);

            // Add hidden inputs
            const container = document.getElementById('ingredientHiddenInputs');
            const prefix = `Ingredients[${idx}]`;
            let html = `
                <input type="hidden" name="${prefix}.IngredientId" value="${data.ingredientId}" data-idx="${idx}" />
                <input type="hidden" name="${prefix}.Quantity" value="${data.qty}" data-idx="${idx}" />
                <input type="hidden" name="${prefix}.Unit" value="${data.unit}" data-idx="${idx}" />
            `;

            if (data.isNew) {
                html += `
                    <input type="hidden" name="${prefix}.NewIngredientName" value="${data.name}" data-idx="${idx}" />
                    <input type="hidden" name="${prefix}.NewCaloriesPer100g" value="${data.newCal}" data-idx="${idx}" />
                    <input type="hidden" name="${prefix}.NewProteins" value="${data.newProt}" data-idx="${idx}" />
                    <input type="hidden" name="${prefix}.NewCarbs" value="${data.newCarbs}" data-idx="${idx}" />
                    <input type="hidden" name="${prefix}.NewFats" value="${data.newFats}" data-idx="${idx}" />
                `;
            }

            container.insertAdjacentHTML('beforeend', html);
            updateCount();
        }

        function removeIngredient(idx) {
            // Remove from array
            const i = ingredients.findIndex(x => x.index === idx);
            if (i !== -1) ingredients.splice(i, 1);

            // Remove table row
            const row = document.getElementById('ingredientRow_' + idx);
            if (row) row.remove();

            // Remove hidden inputs
            document.querySelectorAll(`[data-idx="${idx}"]`).forEach(el => el.remove());

            // Show "no ingredients" if empty
            if (ingredients.length === 0) {
                const noRow = document.getElementById('noIngredientsRow');
                if (noRow) noRow.style.display = '';
            }

            updateCount();
        }

        function updateCount() {
            document.getElementById('ingredientCount').textContent = ingredients.length;
        }
    </script>
}
