@model paw_np.Models.ViewModels.FoodJournalIndexViewModel

@{
    ViewData["Title"] = "Meals Journal";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Meals Journal</h1>
    <a asp-action="Create" class="btn btn-success">Create Journal</a>
</div>

@if (!Model.Journals.Any())
{
    <div class="alert alert-info">No journals available.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Date</th>
                <th>User ID</th>
                <th>Total kcal</th>
                <th>Entries</th>
                <th>Notes</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var journal in Model.Journals.OrderByDescending(item => item.JournalDate))
        {
            <tr>
                <td>@journal.JournalDate.ToString("yyyy-MM-dd")</td>
                <td>@journal.UserId</td>
                <td>@journal.TotalKcalConsumed</td>
                <td>@journal.EntriesCount</td>
                <td>@(string.IsNullOrWhiteSpace(journal.Notes) ? "-" : journal.Notes)</td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@journal.Id" class="btn btn-sm btn-outline-primary">Details</a>
                    <a asp-action="Edit" asp-route-id="@journal.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@journal.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
