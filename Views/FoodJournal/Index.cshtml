@model paw_np.Models.ViewModels.FoodJournalIndexViewModel

@{
    ViewData["Title"] = "Meals Journal";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Meals Journal</h1>
    <a asp-action="Create" class="btn btn-primary">+ Create Journal</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th class="text-center">Total kcal</th>
                        <th class="text-center">Entries</th>
                        <th>Notes</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Journals.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">No journals available. Start by creating one!</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var journal in Model.Journals.OrderByDescending(item => item.JournalDate))
                        {
                            <tr>
                                <td class="fw-bold">
                                    <i class="bi bi-calendar-event text-muted me-2"></i>
                                    @journal.JournalDate.ToString("MMM dd, yyyy")
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-primary rounded-pill">@Math.Round(journal.TotalKcalConsumed, 1)</span>
                                </td>
                                <td class="text-center">@journal.EntriesCount</td>
                                <td>
                                    <span class="text-muted text-truncate d-inline-block" style="max-width: 250px;">
                                        @(string.IsNullOrWhiteSpace(journal.Notes) ? "-" : journal.Notes)
                                    </span>
                                </td>
                                <td class="text-end pe-3">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@journal.Id" class="btn btn-sm btn-outline-info">Details</a>
                                        <a asp-action="Edit" asp-route-id="@journal.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                        <a asp-action="Delete" asp-route-id="@journal.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
