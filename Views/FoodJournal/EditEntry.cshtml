@model paw_np.Models.ViewModels.FoodJournalEntryFormViewModel

@{
    ViewData["Title"] = "Edit Entry";
}

<h1 class="h3 mb-3">Edit Entry</h1>

<div class="card">
    <div class="card-body">
        <form asp-action="EditEntry" asp-route-id="@Model.Id" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="JournalId" />

            <!-- Entry type toggle -->
            <div class="mb-3">
                <label class="form-label fw-bold">What are you logging?</label>
                <div class="btn-group w-100" role="group">
                    <input type="radio" class="btn-check" name="entryType" id="typeRecipe" value="recipe" @(Model.RecipeId.HasValue ? "checked" : "") onchange="toggleEntryType()">
                    <label class="btn btn-outline-success" for="typeRecipe">A Recipe</label>
                    <input type="radio" class="btn-check" name="entryType" id="typeIngredient" value="ingredient" @(!Model.RecipeId.HasValue ? "checked" : "") onchange="toggleEntryType()">
                    <label class="btn btn-outline-info" for="typeIngredient">An Ingredient</label>
                </div>
            </div>

            <div class="row g-3">
                <!-- Recipe selector -->
                <div class="col-md-6" id="recipeGroup">
                    <label class="form-label">Recipe</label>
                    <select asp-for="RecipeId" class="form-select" id="recipeSelect" onchange="calculateKcal()">
                        <option value="">-- Select recipe --</option>
                        @foreach (var recipe in Model.AvailableRecipes)
                        {
                            <option value="@recipe.Id"
                                    data-totalkcal="@recipe.TotalKcal"
                                    data-servings="@recipe.Servings">@recipe.Name</option>
                        }
                    </select>
                </div>

                <!-- Ingredient selector -->
                <div class="col-md-6 d-none" id="ingredientGroup">
                    <label class="form-label">Ingredient</label>
                    <select asp-for="IngredientId" class="form-select" id="ingredientSelect" onchange="calculateKcal()">
                        <option value="">-- Select ingredient --</option>
                        @foreach (var ingredient in Model.AvailableIngredients)
                        {
                            <option value="@ingredient.Id"
                                    data-calper100="@ingredient.CaloriesPer100g">@ingredient.Name</option>
                        }
                    </select>
                </div>

                <div class="col-md-6">
                    <label asp-for="Quantity" class="form-label" id="qtyLabel">Servings</label>
                    <input asp-for="Quantity" class="form-control" id="qtyInput" type="number" step="0.01" min="0.01" oninput="calculateKcal()" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="MealType" class="form-label"></label>
                    <select asp-for="MealType" class="form-select">
                        <option value="Breakfast">Mic dejun</option>
                        <option value="Lunch">Pranz</option>
                        <option value="Dinner">Cina</option>
                        <option value="Snack">Snack</option>
                    </select>
                    <span asp-validation-for="MealType" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Kcal (auto)</label>
                    <input type="text" class="form-control bg-light" id="kcalPreview" value="@Math.Round(Model.KcalConsumed, 1)" readonly />
                </div>

                <div class="col-md-4">
                    <label asp-for="LoggedAt" class="form-label"></label>
                    <input asp-for="LoggedAt" class="form-control" type="datetime-local" />
                    <span asp-validation-for="LoggedAt" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Details" asp-route-id="@Model.JournalId" class="btn btn-link">Back to Details</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function toggleEntryType() {
            const isRecipe = document.getElementById('typeRecipe').checked;
            const recipeGroup = document.getElementById('recipeGroup');
            const ingredientGroup = document.getElementById('ingredientGroup');
            const qtyLabel = document.getElementById('qtyLabel');

            if (isRecipe) {
                recipeGroup.classList.remove('d-none');
                ingredientGroup.classList.add('d-none');
                document.getElementById('ingredientSelect').value = '';
                qtyLabel.textContent = 'Servings';
                document.getElementById('qtyInput').step = 'any';
            } else {
                recipeGroup.classList.add('d-none');
                ingredientGroup.classList.remove('d-none');
                document.getElementById('recipeSelect').value = '';
                qtyLabel.textContent = 'Grams (g)';
                document.getElementById('qtyInput').step = 'any';
            }

            calculateKcal();
        }

        function calculateKcal() {
            const isRecipe = document.getElementById('typeRecipe').checked;
            const qty = parseFloat(document.getElementById('qtyInput').value) || 0;
            let kcal = 0;

            if (isRecipe) {
                const select = document.getElementById('recipeSelect');
                const option = select.options[select.selectedIndex];
                if (option && option.value) {
                    const totalKcal = parseFloat(option.dataset.totalkcal) || 0;
                    const servings = parseInt(option.dataset.servings) || 1;
                    const kcalPerServing = totalKcal / servings;
                    kcal = kcalPerServing * qty;
                }
            } else {
                const select = document.getElementById('ingredientSelect');
                const option = select.options[select.selectedIndex];
                if (option && option.value) {
                    const calPer100 = parseFloat(option.dataset.calper100) || 0;
                    kcal = calPer100 * qty / 100;
                }
            }

            document.getElementById('kcalPreview').value = Math.round(kcal * 10) / 10;
        }

        // Initialize display based on existing values
        document.addEventListener("DOMContentLoaded", function() {
            const recipeId = document.getElementById('recipeSelect').value;
            if (recipeId) {
                document.getElementById('typeRecipe').checked = true;
            } else {
                document.getElementById('typeIngredient').checked = true;
            }
            toggleEntryType();
            
            // Re-set initial kcal to avoid overwriting existing data if unmodified
            document.getElementById('kcalPreview').value = '@Math.Round(Model.KcalConsumed, 1)';
        });
    </script>
}
