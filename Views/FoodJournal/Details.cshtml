@model paw_np.Models.ViewModels.FoodJournalDetailsViewModel

@{
    ViewData["Title"] = "Journal Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Journal @Model.Journal.JournalDate.ToString("yyyy-MM-dd")</h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Journal.Id" class="btn btn-outline-secondary">Edit Journal</a>
        <a asp-action="Delete" asp-route-id="@Model.Journal.Id" class="btn btn-outline-danger">Delete Journal</a>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <div class="row mb-2">
            <div class="col-md-3"><strong>User ID:</strong> @Model.Journal.UserId</div>
            <div class="col-md-3"><strong>Total kcal:</strong> @Model.TotalKcalConsumed</div>
            <div class="col-md-6"><strong>Notes:</strong> @(string.IsNullOrWhiteSpace(Model.Journal.Notes) ? "-" : Model.Journal.Notes)</div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">Add Entry</div>
    <div class="card-body">
        <form asp-action="AddEntry" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="NewEntryForm.JournalId" />

            <div class="col-md-2">
                <label class="form-label">Recipe</label>
                <select asp-for="NewEntryForm.RecipeId" class="form-select">
                    <option value="">-- Select recipe (optional) --</option>
                    @foreach (var recipe in Model.AvailableRecipes)
                    {
                        <option value="@recipe.Id">@recipe.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Ingredient</label>
                <select asp-for="NewEntryForm.IngredientId" class="form-select">
                    <option value="">-- Select ingredient (optional) --</option>
                    @foreach (var ingredient in Model.AvailableIngredients)
                    {
                        <option value="@ingredient.Id">@ingredient.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label asp-for="NewEntryForm.Quantity" class="form-label"></label>
                <input asp-for="NewEntryForm.Quantity" class="form-control" />
                <span asp-validation-for="NewEntryForm.Quantity" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <label asp-for="NewEntryForm.MealType" class="form-label"></label>
                <select asp-for="NewEntryForm.MealType" class="form-select">
                    <option value="Breakfast">Mic dejun</option>
                    <option value="Lunch">Pranz</option>
                    <option value="Dinner">Cina</option>
                    <option value="Snack">Snack</option>
                </select>
                <span asp-validation-for="NewEntryForm.MealType" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <label asp-for="NewEntryForm.KcalConsumed" class="form-label"></label>
                <input asp-for="NewEntryForm.KcalConsumed" class="form-control" />
                <span asp-validation-for="NewEntryForm.KcalConsumed" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <label asp-for="NewEntryForm.LoggedAt" class="form-label"></label>
                <input asp-for="NewEntryForm.LoggedAt" class="form-control" />
                <span asp-validation-for="NewEntryForm.LoggedAt" class="text-danger"></span>
            </div>

            <div class="col-12">
                <button type="submit" class="btn btn-primary">Add Entry</button>
            </div>
        </form>
    </div>
</div>

@if (!Model.Entries.Any())
{
    <div class="alert alert-info">No entries logged for this day.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Logged at</th>
                <th>Meal</th>
                <th>Entry</th>
                <th>Quantity</th>
                <th>kcal</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var entry in Model.Entries)
        {
            <tr>
                <td>@entry.LoggedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                <td>@entry.MealType</td>
                <td>@entry.EntryName</td>
                <td>@entry.Quantity</td>
                <td>@entry.KcalConsumed</td>
                <td class="text-end">
                    <a asp-action="EditEntry" asp-route-id="@entry.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <form asp-action="DeleteEntry" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@entry.Id" />
                        <input type="hidden" name="journalId" value="@entry.JournalId" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<a asp-action="Index" class="btn btn-link">Back to List</a>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
