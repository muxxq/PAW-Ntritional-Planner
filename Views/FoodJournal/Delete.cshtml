@model paw_np.Models.ViewModels.FoodJournalDeleteViewModel

@{
    ViewData["Title"] = "Delete Journal";
}

<h1 class="h3 mb-3 text-danger">Delete Journal</h1>

<div class="alert alert-warning">
    Are you sure you want to delete this journal? This will remove all entries from that day.
</div>

<dl class="row">
    <dt class="col-sm-3">Date</dt>
    <dd class="col-sm-9">@Model.JournalDate.ToString("yyyy-MM-dd")</dd>

    <dt class="col-sm-3">User ID</dt>
    <dd class="col-sm-9">@Model.UserId</dd>

    <dt class="col-sm-3">Total kcal</dt>
    <dd class="col-sm-9">@Model.TotalKcalConsumed</dd>

    <dt class="col-sm-3">Entries</dt>
    <dd class="col-sm-9">@Model.EntriesCount</dd>
</dl>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-link">Cancel</a>
</form>
