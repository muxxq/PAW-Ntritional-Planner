<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - NutriPlan</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light fixed-top shadow-sm">
        <div class="container">
            <a class="navbar-brand text-success" asp-controller="Home" asp-action="Index">NutriPlan</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Dashboard">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="FoodJournal" asp-action="Index">Meals</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Ingredients" asp-action="Index">Ingredients</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Planner">Planner</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Recipes">Recipes</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="ShoppingList" asp-action="Index">Shopping List</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Profile">Profile</a></li>
                </ul>
                <div class="d-flex">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <span class="navbar-text me-2">Hi, @User.Identity.Name</span>
                        <form asp-controller="Home" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm">Log out</button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Home" asp-action="Login" class="btn btn-outline-primary btn-sm me-1">Log in</a>
                        <a asp-controller="Home" asp-action="Register" class="btn btn-outline-secondary btn-sm">Sign up</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main class="container" style="padding-top:80px; padding-bottom:80px;">
        @RenderBody()
    </main>

    <footer class="bg-light py-3 fixed-bottom">
        <div class="container text-center">
            <span class="text-muted small">&copy; 2026 NutriPlan. All rights reserved.</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/assets/js/main.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>