@model paw_np.Models.ViewModels.MealPlannerIndexViewModel
@{
    ViewData["Title"] = "Meal Planner";
}

<h2 class="mb-4">Meal Planner</h2>

<!-- Planner Calendar -->
<div class="card mb-4">
    <div class="card-header bg-success text-white">Weekly Meal Plan</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-bordered text-center align-middle mb-0" style="table-layout: fixed; min-width: 800px;">
                <thead class="table-light">
                    <tr>
                        <th style="width: 100px;">Meal / Day</th>
                        @foreach (var day in Model.Calendar.Days)
                        {
                            <th>
                                <div>@day.ToString("ddd")</div>
                                <div class="small text-muted">@day.ToString("MMM dd")</div>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var mealType in Model.Calendar.MealTypes)
                    {
                        <tr>
                            <th scope="row" class="bg-light align-middle">@mealType</th>
                            @foreach (var day in Model.Calendar.Days)
                            {
                                var key = $"{day:yyyy-MM-dd}_{mealType}";
                                <td>
                                    @if (Model.Calendar.CellData.TryGetValue(key, out var cell))
                                    {
                                        <div class="p-2 border rounded bg-white shadow-sm mb-1">
                                            <div class="fw-bold text-success mb-1">Planned</div>
                                            <div class="small text-muted mb-2">@cell.ItemsCount items</div>
                                            <a asp-action="Details" asp-route-id="@cell.Id" class="btn btn-sm btn-outline-info w-100 mb-1">View / Edit</a>
                                        </div>
                                    }
                                    else
                                    {
                                        <form asp-controller="MealPlanner" asp-action="Create" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="PlanDate" value="@day.ToString("yyyy-MM-dd")" />
                                            <input type="hidden" name="MealType" value="@mealType" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary w-100">+ Add</button>
                                        </form>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
