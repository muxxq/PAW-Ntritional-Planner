@model paw_np.Models.ViewModels.MealPlannerDeleteViewModel
@{
    ViewData["Title"] = "Delete Meal Plan";
}

<h2 class="mb-4">Delete Meal Plan</h2>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                Are you sure you want to delete this meal plan?
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Date</dt>
                    <dd class="col-sm-8">@Model.PlanDate.ToString("dd MMM yyyy")</dd>

                    <dt class="col-sm-4">Meal Type</dt>
                    <dd class="col-sm-8">@Model.MealType</dd>

                    <dt class="col-sm-4">Planned Items</dt>
                    <dd class="col-sm-8">@Model.ItemsCount</dd>
                </dl>
            </div>
            <div class="card-footer d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>
